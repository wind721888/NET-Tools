<Window x:Class="WpfCustomButtons.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        Width="800" Height="450"
        WindowStartupLocation="CenterScreen"
        StateChanged="Window_StateChanged">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CaptionHeight="0" ResizeBorderThickness="4"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="MainBorder" CornerRadius="8" Background="#1e1e1e">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="WPF Custom Buttons Demo"
                               Foreground="White" FontSize="13"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">

                        <!-- Minimize -->
                        <Button x:Name="MinimizeBtn" Click="Minimize_Click"
                                Width="46" Height="32" Background="Transparent"
                                BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3a3a3a"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#5a5a5a"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Viewbox Width="12" Height="12" Stretch="Uniform">
                                <Canvas Width="12" Height="12">
                                    <Line X1="0" Y1="6" X2="12" Y2="6"
                                          Stroke="White" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <!-- Maximize / Restore -->
                        <Button x:Name="MaximizeBtn" Click="Maximize_Click"
                                Width="46" Height="32" Background="Transparent"
                                BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3a3a3a"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#5a5a5a"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Viewbox Width="12" Height="12" Stretch="Uniform">
                                <Canvas Width="12" Height="12">
                                    <Path x:Name="MaximizeIcon"
                                          Stroke="White" StrokeThickness="1.5"
                                          Data="M 1,1 L 11,1 L 11,11 L 1,11 Z"/>
                                    <Path x:Name="RestoreIconBack" Visibility="Collapsed"
                                          Stroke="White" StrokeThickness="1.5" Fill="#1e1e1e"
                                          Data="M 3,1 L 11,1 L 11,9 L 3,9 Z"/>
                                    <Path x:Name="RestoreIconFront" Visibility="Collapsed"
                                          Stroke="White" StrokeThickness="1.5" Fill="#1e1e1e"
                                          Data="M 1,3 L 9,3 L 9,11 L 1,11 Z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <!-- Close -->
                        <Button x:Name="CloseBtn" Click="Close_Click"
                                Width="46" Height="32" Background="Transparent"
                                BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#e81123"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#f1707a"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Viewbox Width="12" Height="12" Stretch="Uniform">
                                <Canvas Width="12" Height="12">
                                    <Line X1="0" Y1="0" X2="12" Y2="12"
                                          Stroke="White" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="12" Y1="0" X2="0" Y2="12"
                                          Stroke="White" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" CornerRadius="0,0,8,8"
                    Background="#2d2d2d" Padding="20">
                <TextBlock Text="自定义窗口按钮 Demo — 最小化 / 最大化↔还原 / 关闭"
                           Foreground="#999" FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </Border>
</Window>
